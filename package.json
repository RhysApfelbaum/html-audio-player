{
    "name": "html-audio-player",
    "module": "index.js",
    "files": [
        "index.js",
        "assets/**/*"
    ],
    "type": "module",
    "devDependencies": {
        "@alik6/bun-copy-plugin": "^0.0.10",
        "@types/bun": "latest",
        "http-server": "^14.1.1",
        "husky": "^9.1.7",
        "lint-staged": "^16.4.0",
        "prettier": "^3.8.1"
    },
    "peerDependencies": {
        "typescript": "^5"
    },
    "dependencies": {
        "audiomotion-analyzer": "^4.5.4",
        "css-filter-converter": "^1.0.110"
    },
    "lint-staged": {
        "*": [
            "prettier --write --ignore-unknown"
        ]
    },
    "scripts": {
        "build": "bun build ./src/index.ts --outdir ./dist",
        "dev": "bun dev.ts",
        "format": "bunx prettier . --write",
        "prepare": "husky"
    }
